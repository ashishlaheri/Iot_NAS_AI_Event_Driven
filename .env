# ============================================
# IoT-NAS — Environment Configuration
# ============================================
# All services read from this file via docker-compose.yml
# Change credentials before production deployment

# PostgreSQL
POSTGRES_DB=iotnas
POSTGRES_USER=iotnas
POSTGRES_PASSWORD=iotnas2024

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MQTT (Mosquitto)
MQTT_HOST=mosquitto
MQTT_PORT=1883

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=iotnas2024

# Service ports
QUEUE_API_PORT=8001
INFERENCE_API_PORT=8000
FORENSIC_API_PORT=8002

# n8n
N8N_PORT=5678
